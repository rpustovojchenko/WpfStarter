<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<connectionStrings>
		<add name="RecordsConnection"
			 connectionString="Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=Records;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=False;Application Intent=ReadWrite;Multi Subnet Failover=False;Command Timeout=30"
			 providerName="System.Data.SqlClient"/>
	</connectionStrings>
</configuration>